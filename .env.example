# =============================================================================
# Sales Pilot 环境变量
# =============================================================================
# 使用方法：
#   cp .env.example .env
#   编辑 .env，填写真实值；切勿将 .env 提交到 Git（已在 .gitignore 中忽略）。
#
# Docker Compose 会在项目根目录自动读取 .env。
# =============================================================================

# -----------------------------------------------------------------------------
# 通用配置
# -----------------------------------------------------------------------------
# JWT_SECRET：签发会话/JWT 的密钥，生产环境必须改为足够长的随机串。
#   生成示例：openssl rand -hex 32
JWT_SECRET=please-change-me-use-openssl-rand-hex-32-in-production

# APP_BASE_URL：用户浏览器访问本系统的根 URL（含协议与端口，无末尾斜杠）。
#   本地 Docker：http://localhost
#   NAS/公网：如 http://192.168.1.100 或 https://app.example.com
APP_BASE_URL=http://localhost

# FRONTEND_ORIGIN：允许跨域的前端来源，通常与 APP_BASE_URL 一致。
FRONTEND_ORIGIN=http://localhost

# HTTP_PORT：宿主机映射的 HTTP 端口（仅 Nginx 服务）。默认 80。
HTTP_PORT=80

# -----------------------------------------------------------------------------
# NAS / 公网镜像部署（docker-compose.nas.yml）
# -----------------------------------------------------------------------------
# GHCR_OWNER：GitHub 用户名（小写），需与 ghcr.io/<owner>/sales-pilot-* 镜像路径一致。
GHCR_OWNER=6547709

# IMAGE_TAG：镜像标签，与 CI 构建推送的标签一致。
#   常用：latest（跟随 main 最新构建）、sha-xxxxxxx（精确提交）。
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# 数据库（Docker Compose 自动注入，一般无需修改）
# -----------------------------------------------------------------------------
# PostgreSQL：用户 postgres，密码 postgres，库名 sales_pilot
# Docker 网络中服务名：postgres
# 本地端口映射：5432

# =============================================================================
# Sales Pilot 环境变量示例
# =============================================================================
# 使用方法：
#   cp .env.example .env
#   编辑 .env，填写真实值；切勿将 .env 提交到 Git（已在 .gitignore 中忽略）。
#
# Docker Compose 会在**项目根目录**自动读取 .env，用于替换 compose 文件中的 ${VAR}。
# 本地开发（go run / npm run dev）时，可在子目录使用各自的 .env 或 export。
# =============================================================================

# -----------------------------------------------------------------------------
# Docker Compose 通用（docker-compose.yml 与 docker-compose.nas.yml）
# -----------------------------------------------------------------------------
# JWT_SECRET：签发会话/JWT 的密钥，生产环境必须改为足够长的随机串。
#   生成示例：openssl rand -hex 32
JWT_SECRET=please-change-me-use-openssl-rand-hex-32-in-production

# APP_BASE_URL：用户浏览器访问本系统的**根 URL**（含协议与端口，无末尾斜杠）。
#   本地经 Nginx 访问：http://localhost 或 http://localhost:8080（视 HTTP_PORT）
#   NAS / 公网：https://app.example.com 或 http://192.168.1.100
APP_BASE_URL=http://localhost

# FRONTEND_ORIGIN：允许跨域的前端来源，通常与 APP_BASE_URL 一致（含协议与端口）。
FRONTEND_ORIGIN=http://localhost

# HTTP_PORT：宿主机映射的 HTTP 端口（仅 Nginx 服务）。默认 80；无 root 权限时可改为 8080。
HTTP_PORT=80

# -----------------------------------------------------------------------------
# 仅 NAS / 公网镜像部署（docker-compose.nas.yml）
# -----------------------------------------------------------------------------
# GHCR_OWNER：GitHub 用户名（小写），须与 ghcr.io/<owner>/sales-pilot-* 镜像路径一致。
#   Fork 仓库后请改为你自己的用户名；上游仓库默认示例见下。
GHCR_OWNER=6547709

# IMAGE_TAG：从 GHCR 拉取的镜像标签，与 CI 构建推送的标签一致。
#   常用：latest（跟随 main 最新构建）、0.1.42（工作流递增版本）、sha-xxxxxxx（精确提交）。
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# 后端：本地直接运行 go run ./cmd/server（非 Docker）时可选
# -----------------------------------------------------------------------------
# DATABASE_URL：PostgreSQL 连接串。Docker 内由 compose 注入，一般无需在 .env 设置。
# DATABASE_URL=postgres://sales:sales@localhost:5432/sales_pilot?sslmode=disable

# PORT：API 监听端口，默认 8080；仅当进程内读取时生效（见 cmd/server/main.go）。
# PORT=8080

# GIN_MODE：debug 或 release。Compose 中已固定为 release；本地开发可省略或设为 debug。
# GIN_MODE=debug

# -----------------------------------------------------------------------------
# 前端：本地 npm run dev 时，建议在 frontend/.env.local 中配置（Next.js 约定）
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_API_URL：浏览器请求的后端 API 根地址；留空或未设置时默认 http://localhost:8080。
#   与 Nginx 同域生产构建时通常为空，走相对路径 /api/...。
# NEXT_PUBLIC_API_URL=http://localhost:8080
